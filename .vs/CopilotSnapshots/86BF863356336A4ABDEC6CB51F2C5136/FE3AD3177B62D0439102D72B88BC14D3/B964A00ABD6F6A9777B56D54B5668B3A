<!DOCTYPE html>
<html>
<head>
    <title>Setup PIN</title>
<style>
        *{
            box-sizing:border-box
        }
        html,body{
            margin:0;
            padding:0;
            font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
            background:#f4f6f9;
            color:#111827
        }
        body{
            display:flex;
            align-items:center;
            justify-content:center;
            min-height:100vh;
            padding:20px
        }
        .container{
            width:min(100%,420px);
            padding:24px;
            border-radius:16px;
            background:#fff;
            border:1px solid #e5e7eb;
            box-shadow:0 16px 40px rgba(15,23,42,.08)
        }
        h2{
            margin:0 0 18px;
            font-size:1.75rem;
            text-align:center
        }
        form{
            display:grid;
            gap:14px
        }
        input{
            width:100%;
            padding:12px 14px;
            border:1px solid #d1d5db;
            border-radius:12px;
            background:#f8fafc
        }
        input:focus{
            outline:none;
            border-color:#5E8B89
        }
        button{
            width:100%;
            padding:14px 16px;
            border:0;
            border-radius:12px;
            background:#5E8B89;
            color:#fff;
            cursor:pointer
        }
        button:hover{
            background:#476F6D
        }
        .alert{
            color:#dc2626;
            text-align:center;
            margin-top:10px
        }
    </style>
</head>
<body>
    <div class="container">
    <h2>Setup PIN</h2>
    <form method="POST">
        {% csrf_token %}
        <input type="text" name="name" placeholder="Enter name"><br><br>
        <input type="password" name="pin" placeholder="Enter PIN"><br><br>
        <button type="submit">Save PIN</button>
    </form>
</div>
</body>
</html>
