{% extends 'base.html' %}

{% block content %}
<!DOCTYPE html>
<html>
<head>
    <title>Expense History</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            margin: 40px;
        }
        h2 {
            color: #333;
            text-align: center;
        }
        .container {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        th, td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }
        th {
            background: #f0f0f0;
        }
        .delete-btn {
            color: #fff;
            background:#476F6D;
            padding: 6px 12px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 14px;
        }
        .delete-btn:hover {
            background: #5E8B89;
        }
        a {
            display: inline-block;
            margin-top: 15px;
            color: #5E8B89;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Expense History</h2>

    <a href="{% url 'export' %}" class="delete-btn" style="background: #476F6D; margin-bottom: 15px;"> Download </a>

    {% if logs %}
    <table>
        <tr>
            <th>Amount</th>
            <th>Category</th>
            <th>Date</th>
            <th>Action</th>
        </tr>
        {% for log in logs %}
        <tr>
            <td>{{ log.amount }}</td>
            <td>{{ log.category.name }}</td>
            <td>{{ log.date }}</td>
            <td><a href="{% url 'delete' log.id %}" class="delete-btn">Delete</a></td>
        </tr>
        {% endfor %}
    </table>
    {% else %}
        <p>No expenses found.</p>
    {% endif %}

    <a href="{% url 'add' %}">Add New Expense</a>
</div>

</body>
</html>
{% endblock %}