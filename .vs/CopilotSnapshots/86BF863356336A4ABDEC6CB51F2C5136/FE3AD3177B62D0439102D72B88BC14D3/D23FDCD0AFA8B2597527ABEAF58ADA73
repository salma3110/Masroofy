<!DOCTYPE html>
<html>
<head>
    <title>Account Locked</title>
    <style>
        *{
            box-sizing:border-box
        }
        html,body{
            margin:0;
            padding:0;
            font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
            background:#f4f6f9;
            color:#111827
        }
        body{
            display:flex;
            align-items:center;
            justify-content:center;
            min-height:100vh;
            padding:20px
        }
        .container{
            width:min(100%,420px);
            padding:24px;
            border-radius:16px;
            background:#fff;
            border:1px solid #e5e7eb;
            box-shadow:0 16px 40px rgba(15,23,42,.08);
            text-align:center
        }
        h2{
            margin:0 0 16px;
            font-size:1.75rem;
            color:#dc2626
        }
        p{
            margin:0;
            line-height:1.7;
            color:#6b7280
        }
        #countdown{
            font-weight:700;
            color:#dc2626
        }
    </style>
</head>
<body>
    <div class="container">
    <h2>Account Locked</h2>
    <p>Please try again in <span id="countdown">30</span> seconds.</p>
    </div>
    <script>
        let time = 30; // 30 seconds lockout
        let countdown = document.getElementById('countdown');
        setInterval(function(){
            time --;
            countdown.innerText=time;
            if(time <= 0){
                window.location.href = 'http://127.0.0.1:8000/auth/login/'; // Redirect to login after countdown
            }
        } , 1000);
    </script>
</body>
</html>